<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inmobiliaria Profesional</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #f4f6f9;
}

/* HEADER */
header {
  background: #1e3a5f;
  color: white;
  padding: 30px;
  text-align: center;
}

header h1 {
  margin: 0;
}

/* GRID */
.container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 20px;
  padding: 30px;
}

/* TARJETAS */
.card {
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 6px 15px rgba(0,0,0,0.1);
  transition: 0.2s;
}

.card:hover {
  transform: translateY(-5px);
}

.card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.card-content {
  padding: 15px;
}

.price {
  font-size: 22px;
  font-weight: bold;
  color: #1e3a5f;
}

/* BOTÓN */
.phone {
  display: block;
  margin-top: 10px;
  background: #1e3a5f;
  color: white;
  text-align: center;
  padding: 12px;
  border-radius: 8px;
  text-decoration: none;
}

/* FOOTER */
footer {
  background: #1e3a5f;
  color: white;
  text-align: center;
  padding: 20px;
}
</style>

</head>
<body>

<header>
  <h1>Inmobiliaria Juan</h1>
  <p>Encuentra tu hogar ideal</p>
</header>

<div class="container">

  <div class="card">
    <img src="https://picsum.photos/400/300?house1">
    <div class="card-content">
      <h3>Piso en el centro</h3>
      <p>3 habitaciones · 2 baños · 90m²</p>
      <p class="price">150.000€</p>
      <a href="tel:+34600000000" class="phone">📞 Llamar</a>
    </div>
  </div>

  <div class="card">
    <img src="https://picsum.photos/400/300?house2">
    <div class="card-content">
      <h3>Chalet con piscina</h3>
      <p>4 habitaciones · 3 baños · 200m²</p>
      <p class="price">320.000€</p>
      <a href="tel:+34600000000" class="phone">📞 Llamar</a>
    </div>
  </div>

  <div class="card">
    <img src="https://picsum.photos/400/300?house3">
    <div class="card-content">
      <h3>Apartamento moderno</h3>
      <p>2 habitaciones · 1 baño · 70m²</p>
      <p class="price">120.000€</p>
      <a href="tel:+34600000000" class="phone">📞 Llamar</a>
    </div>
  </div>

</div>

<footer>
  <p>📞 Teléfono: +34 600 000 000</p>
</footer>
